# Copie para .env (e/ou .dev.vars para wrangler dev). Nunca commite segredos.
#
# Replicação por cliente: altere apenas estes valores entre projetos.

# Pixel do Meta (Conversions API)
PIXEL_ID=

# Token de acesso com ads_management ou eventos CAPI conforme documentação Meta
META_ACCESS_TOKEN=

# Versão da Graph API (ex.: v21.0)
META_API_VERSION=v21.0

# Origens permitidas no CORS (HTTPS), separadas por vírgula. Obrigatório em produção.
# Ex.: https://www.cliente.com,https://cliente.com
ALLOWED_ORIGINS=

# production = CORS estrito (padrão). development = permite testes com * ou vazio.
WORKER_ENV=production

# Opcional: Test Events no Events Manager (ex.: TEST7356). Remova em tráfego real.
# TEST_EVENT_CODE=TEST7356

# Em erro da Meta, incluir corpo na resposta ao browser (padrão: não).
EXPOSE_META_ERRORS=false

# URL pública do Worker (referência — o tracker usa data-endpoint)
# WORKER_EVENT_URL=https://seu-worker.workers.dev/event

# Painel interno: /dashboard — mesmo valor que secret MONITOR_TOKEN no Worker
# MONITOR_TOKEN=

# Webhook de lead: POST /webhook/lead (token dedicado para integração externa)
# WEBHOOK_TOKEN=

# KV opcional EVENT_LOG (histórico do monitor): configure em wrangler.toml — ver directives/monitor_painel.md
