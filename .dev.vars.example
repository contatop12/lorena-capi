# Renomeie para .dev.vars para `wrangler dev` (não commitar .dev.vars)
# Mesmas chaves que .env.example — espelho para desenvolvimento local do Worker.
# Segredos: META_ACCESS_TOKEN, MONITOR_TOKEN, WEBHOOK_TOKEN (opcional em dev).

PIXEL_ID=
META_ACCESS_TOKEN=
META_API_VERSION=v21.0
# Local: use development + * se precisar testar de qualquer origem
WORKER_ENV=development
ALLOWED_ORIGINS=*
# TEST_EVENT_CODE=TEST7356
EXPOSE_META_ERRORS=true

# Referência da URL pública (não lida pelo Worker; útil para snippets)
# WORKER_EVENT_URL=http://127.0.0.1:8787/event

# Painel /dashboard — em dev pode ficar vazio se WORKER_ENV=development
# MONITOR_TOKEN=

# Webhook /webhook/lead — em dev pode ficar vazio se WORKER_ENV=development
# WEBHOOK_TOKEN=
